# ==============================
# Laravel Backend .gitignore
# ==============================

# Dependencies
/vendor
/node_modules

# Environment files
.env
.env.*
!.env.example

# Laravel storage
/storage/*.key
/storage/app/public
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*

# Bootstrap cache
/bootstrap/cache/*.php

# Public storage symlink
/public/storage

# PHPUnit
/phpunit.result.cache

# IDE / OS
.DS_Store
Thumbs.db
.vscode
.idea

# Logs
*.log

# Coverage
coverage

# Raw catalog data (large source files — not committed to repo)
# Directory structure (.gitkeep) and READMEs ARE tracked; data files are not
/database/data/**/*.json
/database/data/**/*.csv
/database/data/**/*.xls
/database/data/**/*.xlsx
/database/data/backups/
/database/backups/
/database/data/siiu_raw/

# Debug / utility scripts
check_certs.php
debug_geocode.php
nul
backup-database.bat
restore-database.bat
test-multiple.bat
test-multiple.sh
DATOS_FALTANTES.md
